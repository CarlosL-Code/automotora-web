generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  marca        String   @db.VarChar(100)
  modelo       String   @db.VarChar(100)
  ano          Int
  precio       Float
  kilometraje  Int
  transmision  String   @db.VarChar(50)
  combustible  String   @db.VarChar(50)
  motor        String?  @db.VarChar(100)
  color        String?  @db.VarChar(50)
  descripcion  String?  @db.Text
  estado       String   @default("DISPONIBLE") @db.VarChar(50)
  imagenes     String   @db.Text
  destacado    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Staff {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(150)
  cargo        String   @db.VarChar(100)
  descripcion  String?  @db.Text
  imagenUrl    String?  @db.VarChar(500)
  telefono     String?  @db.VarChar(50)
  email        String?  @db.VarChar(150)
  esEjecutivo  Boolean  @default(false)
  orden        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
